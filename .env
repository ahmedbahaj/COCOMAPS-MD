# PDB Analysis Pipeline Configuration
# =====================================

# Docker Images
COCOMAPS_IMAGE_REDUCE=andrpet/cocomaps-backend:0.0.19
COCOMAPS_IMAGE_NO_REDUCE=sattamaltwaim/cocomaps-backend:no-reduce

# Pipeline Settings (true/false)
COCOMAPS_USE_REDUCE=false
SELECT_INTERFACE=false

# Input file name for CoCoMaps
INPUT_FILE_NAME=example_input.json

# Default interface/water selection cutoff in Angstroms
# (used for both protein interface and bridging water detection)
DEFAULT_INTERFACE_CUTOFF=5.0

# Default chains to analyze (comma-separated)
DEFAULT_CHAINS=A,B
