#!/usr/bin/env python3
"""
Cross-platform wrapper that runs coco-md inside Docker.

Handles relative paths, absolute paths, and interactive mode on
Windows, Linux, and macOS.

Install:
  # Pull the image
  docker pull sattamaltwaim/cocomaps-md-cli

  # Linux / macOS — place onto PATH
  sudo curl -fsSL https://raw.githubusercontent.com/sattamaltwaim/COCOMAPS-MD/master/coco-md -o /usr/local/bin/coco-md
  sudo chmod +x /usr/local/bin/coco-md

  # Windows (from an admin prompt)
  copy coco-md "%USERPROFILE%\\bin\\coco-md.py"
  # (add %USERPROFILE%\\bin to PATH if not already there)
"""

import os
import sys
import subprocess
from pathlib import Path

IMAGE = "sattamaltwaim/cocomaps-md-cli"

# Arguments that take a file/directory path as their next value
_PATH_FLAGS = {"-o", "--output", "-p", "--params"}


def _resolve(raw: str) -> Path:
    return Path(raw).resolve()


def main():
    args = sys.argv[1:]
    mounts: dict[str, str] = {}   # host_dir -> container_dir
    rewritten: list[str] = []
    cwd = Path.cwd().resolve()

    # Always mount cwd — default output lands here
    mounts[str(cwd)] = "/data/cwd"

    mount_counter = 0

    def add_mount(host_path: Path) -> str:
        """Register a mount for the directory containing host_path.
        Returns the rewritten path inside the container."""
        nonlocal mount_counter
        parent = str(host_path.parent)
        if parent not in mounts:
            mount_counter += 1
            mounts[parent] = f"/data/m{mount_counter}"
        return mounts[parent] + "/" + host_path.name

    # Parse args just enough to find paths and rewrite them
    i = 0
    positional_seen = False
    while i < len(args):
        arg = args[i]

        if arg in _PATH_FLAGS and i + 1 < len(args):
            rewritten.append(arg)
            i += 1
            host = _resolve(args[i])
            if arg in ("-o", "--output"):
                # Output dir — mount its parent so the dir can be created
                host.mkdir(parents=True, exist_ok=True)
                container_path = add_mount(host)
            else:
                container_path = add_mount(host)
            rewritten.append(container_path)

        elif not arg.startswith("-") and not positional_seen:
            # First positional arg = pdb_file
            positional_seen = True
            host = _resolve(arg)
            if not host.exists():
                print(f"Error: file not found: {arg}", file=sys.stderr)
                sys.exit(1)
            rewritten.append(add_mount(host))

        else:
            rewritten.append(arg)

        i += 1

    # Build docker command
    tty_flags = ["-it"] if sys.stdin.isatty() else []
    cmd = [
        "docker", "run", "--rm", *tty_flags,
        "--platform", "linux/amd64",
        "-w", "/data/cwd",
    ]

    for host_dir, container_dir in mounts.items():
        cmd += ["-v", f"{host_dir}:{container_dir}"]

    cmd.append(IMAGE)
    cmd.extend(rewritten)

    sys.exit(subprocess.call(cmd))


if __name__ == "__main__":
    main()
