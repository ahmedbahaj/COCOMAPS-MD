# CLI and setup.py are needed by Dockerfile.cli;
# the backend Dockerfile simply does not COPY them.

# Dependencies / build artifacts
node_modules/
.venv/
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# Data and temp files
systems/
systems.zip
temp/
documentation/

# Git / editor
.git/
.gitignore
.cursor/
*.md
!backend/README.md
!scripts/README.md

# Tests (not needed in production image)
tests/
pytest.ini
.pytest_cache/

# Docker files (avoid nesting)
Dockerfile.*
docker-compose.yml
.dockerignore
